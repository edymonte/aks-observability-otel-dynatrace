{
  "name": "otel-demo-app",
  "version": "1.0.0",
  "description": "Node.js app instrumentada com OpenTelemetry (HTTP/protobuf), exportando para Dynatrace via OTEL Collector",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",

    "@opentelemetry/sdk-node": "^0.53.0",
